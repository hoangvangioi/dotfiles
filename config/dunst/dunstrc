[global]
    title = Dunst
    class = Dunst
    follow = mouse
    origin = bottom-center
    progress_bar = false
    vertical_alignment = center
    font = JetBrainsMono Nerd Font 10

    width = (110, 300)
    height = (0, 100)
    offset = (15, 15)
    
    corner_radius = 10 
    separator_height = 1
    padding = 16
    horizontal_padding = 24
    text_icon_padding = 16
    alignment = left
    frame_width = 1
    frame_color = "#303446"
    separator_color = foreground

    min_icon_size = 0
    max_icon_size = 64
    icon_corner_radius = 10
    icon_path = /usr/share/icons/Papirus/24x24/panel/:/usr/share/icons/Papirus/24x24/status/
    icon_theme = Papirus
    enable_recursive_icon_lookup = true

    timeout = 3
    sort = true 
    markup = full
    line_height = 0
    stack_duplicates = false
    hide_duplicate_count = true 
    word_wrap = yes
    ellipsize = end
    show_indicators = yes
    indicate_hidden = false 
    idle_threshold = 120s
    show_age_threshold = 60
    dmenu = /usr/bin/rofi -p dunst:
    browser = /usr/bin/firefox --new-tab

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#1e1e2e"
    foreground = "#99AEB3"
    timeout = 8

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#99AEB3"
    timeout = 8

[urgency_critical]
    background = "#EBA0AC"
    foreground = "#1E1E2E"
    frame_color = "#F38BA8"
    timeout = 0


[backlight]
    appname = "Backlight"
    highlight = "#fc7b80"

[music]
    appname = "Music"

[volume]
    summary = "Volume*"
    highlight = "#cb8cf4"

[battery]
    appname = "Battery"